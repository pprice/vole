// Helper module for iter_find_cross_module.vole
//
// Creates an Iterator<bool> via .map() which causes codegen to
// compile Iterable default methods (find, first, last, nth) for the
// bool element type. Without the corresponding Optional<bool> sema
// TypeId, this previously caused:
//   "iterator method return type not found: find (expr_id=None)"

// This function produces an Iterator<bool> by mapping i64 → bool.
func map_to_bools(arr: [i64]) -> [bool] {
    return arr.iter().map((x) => x > 0).collect()
}

// A second function to ensure the module has enough iterator usage
// to trigger cross-module type table merging.
func count_positives(arr: [i64]) -> i64 {
    return arr.iter().filter((x) => x > 0).count()
}
