tests "string interpolation" {
    test "simple variable" {
        let name = "world"
        let s = "hello, {name}"
        assert(s == "hello, world")
    }

    test "expression" {
        let a = 2
        let b = 3
        let s = "sum is {a + b}"
        assert(s == "sum is 5")
    }

    test "multiple interpolations" {
        let x = 1
        let y = 2
        let s = "{x} + {y} = {x + y}"
        assert(s == "1 + 2 = 3")
    }

    test "empty text segments" {
        let x = 42
        let s = "{x}"
        assert(s == "42")
    }

    test "nested expressions" {
        let arr = [1, 2, 3]
        let s = "first: {arr[0]}, length: {arr.length()}"
        assert(s == "first: 1, length: 3")
    }

    test "integer" {
        let n = 42
        let s = "number: {n}"
        assert(s == "number: 42")
    }

    test "float" {
        let f = 3.14
        let s = "pi: {f}"
        assert(s == "pi: 3.14")
    }

    test "boolean true" {
        let b = true
        let s = "value: {b}"
        assert(s == "value: true")
    }

    test "boolean false" {
        let b = false
        let s = "value: {b}"
        assert(s == "value: false")
    }

    test "nil value" {
        let x: i32? = nil
        let s = "value: {x}"
        assert(s == "value: nil")
    }

    test "array small" {
        let arr = [1, 2, 3]
        let s = "arr: {arr}"
        assert(s == "arr: [1, 2, 3]")
    }

    test "array truncated" {
        let arr = [1, 2, 3, 4, 5, 6, 7]
        let s = "arr: {arr}"
        assert(s == "arr: [1, 2, 3, 4, 5, ...]")
    }

    test "escaped braces" {
        let s = "literal {{braces}}"
        assert(s == "literal {{braces}}")
    }

    test "backslash escaped braces are literal" {
        let s = "literal \{braces\}"
        assert(s == "literal \{braces\}")
    }

    test "method call in interpolation" {
        let arr = [1, 2, 3, 4, 5]
        let s = "length: {arr.length()}"
        assert(s == "length: 5")
    }

    // Regression: when expressions inside interpolation must convert their
    // result to string, not pass raw integer values.  The constant folding
    // optimizer replaces `when` with its arm body, changing the node ID and
    // losing the StringConversion annotation (vol-ltjx).
    test "i64 when in interpolation" {
        let x = 10
        let s = "result: {when {
            x > 5 => x * 2
            _ => 0
        }}"
        assert(s == "result: 20")
    }

    test "when in interpolation with wildcard arm" {
        let x = 1
        let s = "result: {when {
            x > 100 => x
            _ => x + 5
        }}"
        assert(s == "result: 6")
    }

    test "when in interpolation with string result" {
        let x = true
        let s = "flag: {when {
            x => "yes"
            _ => "no"
        }}"
        assert(s == "flag: yes")
    }
}

// Regression: generic function monomorphized with multiple type args must
// re-derive StringConversion per instance.  Previously the VIR template
// captured the identity-analysis conversion (I64ToString for TypeParam)
// and all instances inherited it, treating string/bool values as i64
// (vol-vrjl).
func interp_generic<T>(item: T) -> string {
    return "value: {item}"
}

tests "generic interpolation" {
    test "i64 first" {
        let r = interp_generic(42)
        assert(r == "value: 42")
    }
    test "string second" {
        let r = interp_generic("hello")
        assert(r == "value: hello")
    }
    test "bool third" {
        let r = interp_generic(true)
        assert(r == "value: true")
    }
    test "float" {
        let r = interp_generic(3.14)
        assert(r == "value: 3.14")
    }
}

tests "raw strings" {
    test "basic" {
        let s = @"hello"
        assert(s == "hello")
    }

    test "with braces not interpolated" {
        let s = @"{not interpolated}"
        assert(s.length() == 18)
    }

    test "with backslash" {
        let s = @"path\to\file"
        assert(s.length() == 12)
    }

    test "regex pattern" {
        let pattern = @"^\d{3}-\d{4}$"
        assert(pattern.length() == 13)
    }
}
