// Test: methods work correctly without explicit self parameter.
// `self` is always implicit in methods — it cannot be used as a parameter name (E2126).

class Counter {
    value: i64
}

implement Counter {
    func get() -> i64 => self.value
    func increment(amount: i64) -> i64 => self.value + amount
}

class Point {
    x: i64,
    y: i64,

    func sum() -> i64 => self.x + self.y
    func offset(dx: i64, dy: i64) -> i64 => self.x + dx + self.y + dy
}

tests "implicit self in methods" {
    test "implement block method, no args" {
        let c = Counter { value: 42 }
        assert(c.get() == 42)
    }

    test "implement block method with args" {
        let c = Counter { value: 10 }
        assert(c.increment(5) == 15)
    }

    test "class body method, no args" {
        let p = Point { x: 3, y: 4 }
        assert(p.sum() == 7)
    }

    test "class body method with args" {
        let p = Point { x: 1, y: 2 }
        assert(p.offset(10, 20) == 33)
    }

    test "closure capturing class and calling method" {
        let c = Counter { value: 42 }
        let get_val = () => c.get()
        assert(get_val() == 42)
    }

    test "closure capturing class and calling method with args" {
        let c = Counter { value: 10 }
        let inc = (n: i64) => c.increment(n)
        assert(inc(5) == 15)
    }

    test "multiple method calls on same captured instance" {
        let c = Counter { value: 7 }
        let f = () => c.get() + c.increment(3)
        assert(f() == 17)
    }
}
