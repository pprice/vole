// Regression: vtable meta getter must handle non-class/non-struct concrete
// types (e.g. arrays boxed as Iterator). Previously, compile_meta_getter
// only handled function/closure and class/struct, causing an internal error
// when an array was coerced to Iterator inside a generic function body.

func filter_positive<T>(arr: [i64], extra: T) -> [i64] {
    return arr.iter().filter((x) => x > 0).collect()
}

func map_double<T>(arr: [i64], tag: T) -> [i64] {
    return arr.iter().map((x) => x * 2).collect()
}

tests "array_boxed_as_iterator" {
    test "filter in generic function boxes array as Iterator" {
        let result = filter_positive([1_i64, -2_i64, 3_i64, -4_i64], "tag")
        assert(result.length() == 2)
        assert(result[0] == 1)
        assert(result[1] == 3)
    }

    test "map in generic function boxes array as Iterator" {
        let result = map_double([10_i64, 20_i64], 42_i32)
        assert(result.length() == 2)
        assert(result[0] == 20)
        assert(result[1] == 40)
    }
}
