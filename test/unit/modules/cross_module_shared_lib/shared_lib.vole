// Shared module imported by multiple test files.
// Regression test for vol-qmjf: VIR must be available for module function.
// Extended for vol-0z7l: VIR must be available for module method (impl_dispatch).

func add(a: i64, b: i64) -> i64 {
    return a + b
}

func greet(name: string) -> string {
    return "hello " + name
}

interface Summarizable {
    func summary() -> string
}

class Point {
    x: i64,
    y: i64,

    func distance() -> i64 {
        return self.x + self.y
    }
}

extend Point with Summarizable {
    func summary() -> string {
        return "Point(" + self.x.to_string() + ", " + self.y.to_string() + ")"
    }
}
